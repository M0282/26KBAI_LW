# 이 파일을 .env 로 복사한 뒤 값을 채울 것. .env 는 절대 커밋 금지.
ANTHROPIC_API_KEY=
# 국가법령정보센터 Open API 인증(OC) — https://open.law.go.kr 에서 신청 (승인 대기 있으니 즉시 신청!)
LAW_API_OC=
# OCR이 못 읽는 이미지(다크모드 화면·흐릿한 사진)를 LLM 비전으로 전사. 0=끄기(기본 켬)
# 이미지 1장 ≈ 1.6k 토큰(수 원), 결과 캐시로 재호출 0원, 일반 PDF는 호출되지 않음
VISION_OCR=1
VISION_MODEL=claude-haiku-4-5
